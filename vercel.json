{
  "buildCommand": "pnpm --filter @workspace/rental-platform run build",
  "outputDirectory": "artifacts/rental-platform/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.outdoorshare.rent/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
